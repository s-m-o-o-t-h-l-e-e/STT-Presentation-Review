# Naver CLOVA Speech
CLOVA_SPEECH_SECRET_KEY=<your-clova-speech-secret-key>
CLOVA_SPEECH_INVOKE_URL=<your-clova-speech-invoke-url>

# Claude report/evaluation model
CLAUDE_API_KEY=<your-claude-api-key>
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_TIMEOUT_SECONDS=180

# Azure Speech
AZURE_SPEECH_KEY=<your-azure-speech-key>
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_ENDPOINT=https://eastus.api.cognitive.microsoft.com/

# OpenAI Whisper
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_WHISPER_MODEL=whisper-1

# Google Speech-to-Text v2
# Put the service account JSON file under secrets/google-service-account.json.
GOOGLE_APPLICATION_CREDENTIALS=secrets/google-service-account.json
GOOGLE_CLOUD_PROJECT=<your-google-cloud-project-id>
GOOGLE_SPEECH_LOCATION=global
GOOGLE_SPEECH_RECOGNIZER=_

# Optional fallback for Google Speech-to-Text v1 API-key mode
GOOGLE_SPEECH_API_KEY=<your-google-speech-api-key>

# AssemblyAI
ASSEMBLYAI_API_KEY=<your-assemblyai-api-key>
